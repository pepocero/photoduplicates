<?xml version="1.0" encoding="utf-8"?>
<!--

  Publicación AUTOCONTENIDA (SelfContained + WindowsAppSDKSelfContained).

  Incluye .NET Desktop y Windows App SDK en la carpeta; en el PC destino no hace falta
  instalar el runtime .NET ni el Windows App Runtime (copiar toda la carpeta de salida).

  Si aparece 0xc000027b al arrancar, volver al perfil FDD: etiqueta git pre-self-contained-fdd
  o restaurar SelfContained/WindowsAppSDKSelfContained a false.

  VS: Publicar → FolderWin64. CLI:

  dotnet publish PhotoDuplicates.csproj -c Release -p:PublishProfile=FolderWin64

  Copiar TODA la carpeta de salida (no solo PhotoDuplicates.exe).

-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Debe ser false: un solo archivo + WinUI requiere EnableMsixTooling y suele fallar en desempaquetado -->
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <PublishDir>bin\Publish\win-x64\</PublishDir>
  </PropertyGroup>
</Project>

<?xml version="1.0" encoding="utf-8"?>
<!--

  Publicación DEPENDIENTE DEL FRAMEWORK (recomendada si el modo autocontenido falla con 0xc000027b).

  Carpeta más pequeña; en cada PC destino deben estar instalados:

  - .NET Desktop Runtime 9 x64: https://dotnet.microsoft.com/download/dotnet/9.0

  - Windows App Runtime 1.6 (x64): https://learn.microsoft.com/windows/apps/windows-app-sdk/downloads

  VS: Publicar → FolderWin64. CLI:

  dotnet publish PhotoDuplicates.csproj -c Release -p:PublishProfile=FolderWin64

  Copiar TODA la carpeta de salida (no solo PhotoDuplicates.exe).

-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <!-- Debe ser false: un solo archivo + WinUI requiere EnableMsixTooling y suele fallar en desempaquetado -->
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <PublishDir>bin\Publish\win-x64\</PublishDir>
  </PropertyGroup>
</Project>
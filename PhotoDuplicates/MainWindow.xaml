<Window
    x:Class="PhotoDuplicates.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Duplicados de fotos">

    <!-- Tamaño mínimo: WinUI no admite MinWidth/MinHeight en Window (WMC0011); el Grid raíz sí. -->
    <Grid Padding="20" MinWidth="720" MinHeight="520" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Carpeta a analizar" Margin="0,0,0,8" Opacity="0.7" />

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="FolderPathBox"
                Grid.Column="0"
                Margin="0,0,12,0"
                PlaceholderText="Ej.: C:\Users\...\Pictures"
                IsReadOnly="True" />
            <Button
                x:Name="BrowseButton"
                Grid.Column="1"
                Content="Examinar..."
                Click="BrowseButton_Click"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,12">
            <RadioButton x:Name="ModeExactRadio" Content="Mismo archivo (SHA-256 del fichero)" IsChecked="True" GroupName="Mode" Margin="0,0,0,4" />
            <RadioButton x:Name="ModeVisualRadio" Content="Misma imagen visual (64x64, ignora metadatos)" GroupName="Mode" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button
                x:Name="ScanButton"
                Content="Escanear"
                Click="ScanButton_Click"
                MinWidth="120"
                Margin="0,0,8,0"
                Background="{StaticResource AppSecondaryBrush}"
                Foreground="White" />
            <Button x:Name="CancelScanButton" Content="Cancelar" Click="CancelScanButton_Click" IsEnabled="False" MinWidth="100" Margin="0,0,12,0" />
            <ProgressBar x:Name="ScanProgress" Minimum="0" Maximum="100" Height="10" VerticalAlignment="Center" Width="220" Margin="0,0,12,0" />
            <TextBlock x:Name="ScanStatusText" VerticalAlignment="Center" Text="" TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Border
            Grid.Row="4"
            BorderBrush="{StaticResource AppAccentBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel
                    x:Name="GroupListPaginatorPanel"
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="GroupListPaginatorText"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button
                        x:Name="GroupListPrevButton"
                        MinWidth="100"
                        Click="GroupListPrevPage_Click"
                        Content="« Anterior" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="Grupos por página:"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox
                        x:Name="GroupListPageSizeCombo"
                        MinWidth="88"
                        SelectionChanged="GroupListPageSizeCombo_SelectionChanged"
                        AutomationProperties.Name="Grupos por página en la lista" />
                    <Button
                        x:Name="GroupListNextButton"
                        MinWidth="100"
                        Click="GroupListNextPage_Click"
                        Content="Siguiente »" />
                </StackPanel>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <controls:ItemsRepeater x:Name="GroupsRepeater">
                    <controls:ItemsRepeater.Layout>
                        <controls:StackLayout Orientation="Vertical" Spacing="18" />
                    </controls:ItemsRepeater.Layout>
                    <controls:ItemsRepeater.ItemTemplate>
                        <!-- Binding (no x:Bind): x:Bind en plantillas bajo Window provoca SetConverterLookupRoot(MainWindow) y falla (Window no es FrameworkElement). -->
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,8"
                                    Foreground="{StaticResource AppAccentBrush}"
                                    Text="{Binding GroupTitle}" />
                                <ItemsControl ItemsSource="{Binding PageItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="DuplicateThumb_Click"
                                                    Tag="{Binding FilePath}"
                                                    AutomationProperties.Name="Ampliar miniatura">
                                                    <Border
                                                        Width="108"
                                                        Height="108"
                                                        CornerRadius="6"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                                                        <Grid>
                                                            <Image
                                                                Stretch="Uniform"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Source="{Binding FilePath, Converter={StaticResource FilePathToBitmap}, ConverterParameter=128}" />
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <CheckBox
                                                        IsChecked="{Binding MarkedForDeletion, Mode=TwoWay}"
                                                        Content="Marcar para papelera" />
                                                    <TextBlock
                                                        Text="{Binding FilePath}"
                                                        TextWrapping="Wrap"
                                                        FontSize="12"
                                                        Opacity="0.85"
                                                        Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="{Binding HasMultiplePages, Converter={StaticResource BoolToVisibility}}">
                                    <Button
                                        Content="Archivos ←"
                                        Click="GroupPrevPage_Click"
                                        IsEnabled="{Binding CanPrevPage}" />
                                    <Button
                                        Content="Archivos →"
                                        Click="GroupNextPage_Click"
                                        IsEnabled="{Binding CanNextPage}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </controls:ItemsRepeater.ItemTemplate>
                </controls:ItemsRepeater>
            </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal">
            <Button
                x:Name="DeleteButton"
                Content="Enviar marcados a la papelera"
                Click="DeleteButton_Click"
                IsEnabled="False"
                Margin="0,0,16,0"
                Background="{StaticResource AppDangerBrush}"
                Foreground="White" />
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="" TextWrapping="Wrap" />
        </StackPanel>

        <Button
            Grid.Row="6"
            HorizontalAlignment="Center"
            Margin="0,16,0,0"
            Padding="12,6"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Opacity="0.85"
            Background="Transparent"
            BorderThickness="0"
            Content="Aplicación creada por CarliniTools"
            Click="CarliniToolsCredit_Click" />
    </Grid>
</Window>

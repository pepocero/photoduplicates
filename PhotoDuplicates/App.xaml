<Application
    x:Class="PhotoDuplicates.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:PhotoDuplicates">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <local:FilePathBitmapConverter x:Key="FilePathToBitmap" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#0F6CBD" />
            <SolidColorBrush x:Key="AppSecondaryBrush" Color="#107C10" />
            <SolidColorBrush x:Key="AppDangerBrush" Color="#C42B1C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
